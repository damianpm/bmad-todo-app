# IMPORTANT: replace `replace_me_before_running` with a real password before
# starting the stack. Compose's `${POSTGRES_PASSWORD:?}` guard only catches
# unset/empty values — copying this file verbatim produces a working stack
# with the placeholder password, which is no better than no password at all.

# API
DATABASE_URL=postgres://todos:replace_me_before_running@localhost:5432/todos
PORT=3000
LOG_LEVEL=info
# Comma-separated allowlist. Default covers the prod nginx port (8080) AND
# the vite dev server (5173, both localhost and the typical LAN IP that vite
# prints as the "Network" URL). Add your own origins as needed.
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
NODE_ENV=development

# Web (build-time)
VITE_API_BASE_URL=http://localhost:3000

# Postgres
POSTGRES_DB=todos
POSTGRES_USER=todos
POSTGRES_PASSWORD=replace_me_before_running
